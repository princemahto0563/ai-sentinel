# AI Sentinel – Cloud Functions Environment Variables
# Copy this file to functions/.env and fill in real values
# DO NOT commit the real .env file to source control

# Google Cloud project (auto-set by Firebase, but set explicitly for local dev)
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID
GCLOUD_PROJECT=YOUR_PROJECT_ID

# Vertex AI configuration
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ENDPOINT_ID=YOUR_VERTEX_AI_ENDPOINT_ID
CONFIDENCE_THRESHOLD=0.65

# Gemini model to use
GEMINI_MODEL=gemini-1.5-flash
# GEMINI_API_KEY is set as a Firebase Secret (not in .env):
# firebase functions:secrets:set GEMINI_API_KEY

# Firebase Cloud Messaging topic for fleet-wide alerts
FCM_TOPIC=railway-emergency-alerts
