rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // detections: Cloud Functions write via Admin SDK (bypasses rules).
    // Public read is intentional for the dashboard demo.
    // In production, restrict to authenticated users only.
    match /detections/{detectionId} {
      allow read: if true;
      // Writes come exclusively from Cloud Functions (Admin SDK — bypasses rules).
      allow write: if false;
    }

    // Block all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
